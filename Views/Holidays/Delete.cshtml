@model BusinessManagementSystem.Models.Holiday

@{
    ViewData["Title"] = "Delete Holiday";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fas fa-trash"></i> Delete Holiday?</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        Are you sure you want to delete this holiday?
                    </div>
                    
                    <dl class="row">
                        <dt class = "col-sm-4">Date</dt>
                        <dd class = "col-sm-8">@Model.HolidayDate.ToString("dd MMM yyyy")</dd>
                        <dt class = "col-sm-4">Name</dt>
                        <dd class = "col-sm-8">@Model.HolidayName</dd>
                    </dl>
                    
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="HolidayId" />
                        <div class="d-flex justify-content-between">
                             <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                             <button type="submit" class="btn btn-danger">Delete</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
