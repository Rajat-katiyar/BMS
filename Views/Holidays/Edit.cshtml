@model BusinessManagementSystem.Models.Holiday

@{
    ViewData["Title"] = "Edit Holiday";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark">
                    <h4 class="mb-0"><i class="fas fa-edit"></i> Edit Holiday</h4>
                </div>
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="HolidayId" />
                        <input type="hidden" asp-for="CreatedOn" />

                        <div class="mb-3">
                            <label asp-for="HolidayDate" class="form-label">Date</label>
                            <input asp-for="HolidayDate" class="form-control" type="date" />
                            <span asp-validation-for="HolidayDate" class="text-danger"></span>
                        </div>
                        
                        <div class="mb-3">
                            <label asp-for="HolidayName" class="form-label">Holiday Name</label>
                            <input asp-for="HolidayName" class="form-control" />
                            <span asp-validation-for="HolidayName" class="text-danger"></span>
                        </div>

                        <div class="mb-3 form-check form-switch">
                            <input class="form-check-input" type="checkbox" role="switch" asp-for="IsActive">
                            <label class="form-check-label" asp-for="IsActive">Active</label>
                        </div>

                        <div class="d-grid gap-2">
                             <button type="submit" class="btn btn-warning">Save Changes</button>
                             <a asp-action="Index" class="btn btn-link text-secondary">Back to List</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
