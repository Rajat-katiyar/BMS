@model BusinessManagementSystem.Models.Purchase

@{
    ViewData["Title"] = "Delete Purchase";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0"><i class="fas fa-exclamation-triangle"></i> Delete Purchase</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <i class="fas fa-exclamation-circle"></i> Are you sure you want to delete this purchase?
                        <br/><br/>
                        <strong>This will REVERSE the stock quantity for the product.</strong>
                    </div>

                    <div class="card mb-3">
                        <div class="card-body">
                            <h5 class="card-title">Order for: @Model.Product?.ProductName</h5>
                            <hr />
                            
                            <div class="row mb-2">
                                <div class="col-md-4">
                                    <strong>Vendor:</strong>
                                </div>
                                <div class="col-md-8">
                                    @Model.Vendor?.VendorName
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-4">
                                    <strong>Quantity:</strong>
                                </div>
                                <div class="col-md-8">
                                    @Model.Quantity (will be deducted from stock)
                                </div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-4">
                                    <strong>Total Amount:</strong>
                                </div>
                                <div class="col-md-8">
                                    ₹@Model.TotalAmount.ToString("N2")
                                </div>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="PurchaseId" />
                        
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fas fa-trash"></i> Confirm Delete & Revert Stock
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
