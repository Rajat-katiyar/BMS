@model BusinessManagementSystem.Models.Purchase

@{
    ViewData["Title"] = "Purchase Details";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card shadow">
                <div class="card-header bg-info text-white">
                    <h4 class="mb-0"><i class="fas fa-info-circle"></i> Purchase Details</h4>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Invoice Number:</strong>
                        </div>
                        <div class="col-md-8">
                             <span class="badge bg-secondary">@(Model.InvoiceNumber ?? "N/A")</span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Purchase Date:</strong>
                        </div>
                        <div class="col-md-8">
                            @Model.PurchaseDate.ToString("dd MMM yyyy")
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Vendor:</strong>
                        </div>
                        <div class="col-md-8">
                            <a asp-controller="Vendors" asp-action="Details" asp-route-id="@Model.VendorId">
                                @Model.Vendor?.VendorName
                            </a>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Product:</strong>
                        </div>
                        <div class="col-md-8">
                            <a asp-controller="Products" asp-action="Details" asp-route-id="@Model.ProductId">
                                @Model.Product?.ProductName
                            </a>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Quantity:</strong>
                        </div>
                        <div class="col-md-8">
                            @Model.Quantity
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Unit Price:</strong>
                        </div>
                        <div class="col-md-8">
                            ₹@Model.UnitPrice.ToString("N2")
                        </div>
                    </div>

                    <div class="row mb-3 bg-light p-2 rounded">
                        <div class="col-md-4">
                            <strong class="text-primary">Total Amount:</strong>
                        </div>
                        <div class="col-md-8">
                            <strong class="text-primary">₹@Model.TotalAmount.ToString("N2")</strong>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Notes:</strong>
                        </div>
                        <div class="col-md-8">
                            @(Model.Notes ?? "N/A")
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-4">
                            <strong>Recorded On:</strong>
                        </div>
                        <div class="col-md-8">
                            @Model.CreatedDate.ToString("dd MMM yyyy, hh:mm tt")
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                        <a asp-action="Delete" asp-route-id="@Model.PurchaseId" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete Transaction
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
