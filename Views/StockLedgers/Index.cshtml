@model IEnumerable<BusinessManagementSystem.Models.StockLedger>

@{
    ViewData["Title"] = "Inventory Ledger";
}

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-6">
            <h2><i class="fas fa-history"></i> Inventory Ledger</h2>
        </div>
        <div class="col-md-6 text-end">
            <!-- No manual entry button as this is system generated -->
            <button class="btn btn-outline-secondary" disabled>
                <i class="fas fa-lock"></i> System Generated
            </button>
        </div>
    </div>

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-striped">
                    <thead class="table-dark">
                        <tr>
                            <th>Date</th>
                            <th>Product</th>
                            <th>Type</th>
                            <th>Qty</th>
                            <th>Balance</th>
                            <th>Reference</th>
                            <th>Remarks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.TransactionDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td>@item.Product?.ProductName</td>
                                    <td>
                                        @if (item.TransactionType == "IN")
                                        {
                                            <span class="badge bg-success"><i class="fas fa-arrow-down"></i> IN</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="fas fa-arrow-up"></i> OUT</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.TransactionType == "IN")
                                        {
                                            <span class="text-success fw-bold">+@item.Quantity</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger fw-bold">-@item.Quantity</span>
                                        }
                                    </td>
                                    <td><strong>@item.BalanceQuantity</strong></td>
                                    <td>@item.Reference</td>
                                    <td>@item.Remarks</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted">
                                    <i class="fas fa-clipboard-list fa-3x mt-3"></i>
                                    <p class="mt-2">No inventory transactions found.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
